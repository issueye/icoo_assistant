# Core runtime
AGENT_SYSTEM_PROMPT=You are a coding agent working inside this repository. Use tools to solve tasks.
AGENT_SKILLS_DIR=skills
AGENT_MAX_ROUNDS=20
AGENT_COMMAND_TIMEOUT_SECONDS=120
AGENT_COMPACT_THRESHOLD=50000
AGENT_TRANSCRIPT_DIR=.transcripts

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=16000
ANTHROPIC_ENABLE_PROMPT_CACHE=false
ANTHROPIC_ENABLE_THINKING=true
