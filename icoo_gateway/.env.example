GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=18080
GATEWAY_READ_TIMEOUT_SECONDS=10
GATEWAY_WRITE_TIMEOUT_SECONDS=15
GATEWAY_SHUTDOWN_TIMEOUT_SECONDS=10
GATEWAY_STORAGE_DRIVER=memory
# Used when GATEWAY_STORAGE_DRIVER=sqlite
GATEWAY_SQLITE_PATH=./data/icoo_gateway.db
# Example when using postgres in future versions:
# GATEWAY_DATABASE_URL=postgres://gateway:secret@localhost:5432/icoo_gateway?sslmode=disable
