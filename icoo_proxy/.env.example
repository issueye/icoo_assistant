PROXY_HOST=127.0.0.1
PROXY_PORT=18181
PROXY_READ_TIMEOUT_SECONDS=15
PROXY_WRITE_TIMEOUT_SECONDS=300
PROXY_SHUTDOWN_TIMEOUT_SECONDS=10
PROXY_CHAIN_LOG_PATH=.data/icoo_proxy-chain.log
PROXY_CHAIN_LOG_BODIES=true
# 0 means no truncation.
PROXY_CHAIN_LOG_MAX_BODY_BYTES=0

# Optional downstream key for local clients.
# If empty and PROXY_ALLOW_UNAUTHENTICATED_LOCAL=true, local clients may call without auth.
PROXY_API_KEY=
PROXY_API_KEYS=
PROXY_ALLOW_UNAUTHENTICATED_LOCAL=true

# Defaults: <protocol>:<real-model>
PROXY_DEFAULT_ANTHROPIC_ROUTE=anthropic:claude-sonnet-4-20250514
PROXY_DEFAULT_CHAT_ROUTE=openai-chat:gpt-4o-mini
PROXY_DEFAULT_RESPONSES_ROUTE=openai-responses:gpt-4.1-mini

# Aliases: alias=<protocol>:<real-model>,alias2=<protocol>:<real-model>
PROXY_MODEL_ROUTES=claude-sonnet=anthropic:claude-sonnet-4-20250514,gpt-4o-chat=openai-chat:gpt-4o-mini,assistant-default=openai-responses:gpt-4.1-mini
